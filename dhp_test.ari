; (rule (lhs1 (lambda ((x a) (y a)) (F x x))) rhs)
; (rule (lhs1 (lambda ((x a) (y a)) (F (f x) x))) rhs)
; (rule (lhs1 (lambda ((x a) (y a)) (F (f x) (f (f x))))) rhs)
