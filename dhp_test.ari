(format higher-order)
(sort a)

(fun f (-> a a))
(fun lhs1 (-> (-> a a a) a))
(fun lhs2 (-> (-> (-> a a) a a) a))
(fun lhs3 (-> (-> (-> a a a) a a) a))
(fun rhs a)
(fun c a)

;; DHP rules
; (rule (lhs1 (lambda ((x a) (y a)) (F y x))) rhs)
; (rule (lhs1 (lambda ((x a) (y a)) (F (f x) (f y)))) rhs)
; (rule (lhs2 (lambda ((x (-> a a)) (y a)) (F (x y) (x c)))) rhs)
; (rule (lhs1 (lambda ((x a) (y a)) (F (f x) (f (f y))))) rhs)

