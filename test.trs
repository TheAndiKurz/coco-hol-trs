(format higher-order)

(sort Nat)
(sort Tree)
(fun * (-> Nat Nat Nat))
(fun + (-> Nat Nat Nat))
(fun s (-> Nat Nat))
(fun 0 Nat)
(fun node (-> Nat Tree Tree Tree))
(fun leaf (-> Nat Tree))
(fun sum (-> Tree Nat))
(fun apply (-> (-> Nat Nat) Nat Nat))
(fun higher_apply (-> (-> (-> Nat Nat) Nat) Nat)) ; order(higher_apply) = 4 => second_order = False
(rule (sum (leaf x)) x)
(rule (sum (node x yt zt)) (+ x (+ (sum yt) (sum zt))))
(rule (+ x 0) x)
(rule (+ x (s y)) (s (+ x y)))
(rule (node x yt zt) (node x zt yt))
; (rule (higher_apply F) (F (lambda ((x Nat)) (s x)))) ; order(F) = 3 => second_order = false
; (rule (+ n n) (* (s (s 0)) n)) ; left linear becomes false
; (rule (apply S x) (S x)) ; free variable 'S' not in eta normal form
(rule (apply (lambda ((y Nat)) (S y)) x) (S x)) ; same as the rule above just with eta long form
; (rule (apply s x) (s x)) ; not in eta normal form
; (rule (apply (lambda ((y Nat)) (s y)) x) (s x))
