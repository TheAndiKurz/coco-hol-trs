; @cops 774
(format HRS)
(sort G)
(sort Ar<G_G>)
(fun 0 G)
(fun union (-> G G G))
(fun lam (-> (-> G G) Ar<G_G>))
(fun app (-> Ar<G_G> G G))
(rule (app (lam (lambda ((x G)) (M x))) N) (M N))
(rule (lam (lambda ((x G)) (app L x))) L)
(rule (union x 0) x)
(rule (union 0 y) y)
(rule (union (union x y) z) (union x (union y z)))
(rule (union x y) (union y x))