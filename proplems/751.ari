; @cops 751
(format HRS)
(sort a)
(sort b)
(sort ab)
(sort BGa)
(sort BGb)
(sort BGc)
(sort BGaBGb)
(sort BGbBGc)
(fun abs (-> (-> a b) ab))
(fun app (-> ab a b))
(fun absBG (-> (-> BGa BGb) BGaBGb))
(fun appBG (-> BGaBGb BGa BGb))
(fun banga (-> a BGa))
(fun let (-> BGa (-> a BGb) BGb))
(rule (app (abs (lambda ((x a)) (M x))) N) (M N))
(rule (abs (lambda ((x a)) (app S x))) S)
(rule (appBG (absBG (lambda ((x BGa)) (M1 x))) N1) (M1 N1))
(rule (absBG (lambda ((x BGa)) (appBG S1 x))) S1)
(rule (let L (lambda ((x a)) (appBG P (banga x)))) (appBG P L))
(rule (let (banga R) (lambda ((x a)) (Q x))) (Q R))
(rule (let L (lambda ((x a)) (C (banga x)))) (C L))