; @cops 722
(format HRS)
(sort a)
(sort b)
(sort c)
(sort d)
(sort e)
(fun 0 a)
(fun 1 a)
(fun 2 a)
(fun cons (-> d e e))
(fun f (-> a a a a))
(fun false c)
(fun filter (-> (-> d c) e e))
(fun filter2 (-> c (-> d c) d e e))
(fun g (-> b b b b))
(fun map (-> (-> d d) e e))
(fun nil e)
(fun true c)
(rule (f 0 1 X) (f X X X))
(rule (f Y U V) 2)
(rule 0 2)
(rule 1 2)
(rule (g W W P) P)
(rule (g X1 Y1 Y1) X1)
(rule (map (lambda ((x d)) (G1 x)) nil) nil)
(rule (map (lambda ((x d)) (H1 x)) (cons W1 P1)) (cons (H1 W1) (map (lambda ((x d)) (H1 x)) P1)))
(rule (filter (lambda ((x d)) (F2 x)) nil) nil)
(rule (filter (lambda ((x d)) (Z2 x)) (cons U2 V2)) (filter2 (Z2 U2) (lambda ((x d)) (Z2 x)) U2 V2))
(rule (filter2 true (lambda ((x d)) (I2 x)) P2 X3) (cons P2 (filter (lambda ((x d)) (I2 x)) X3)))
(rule (filter2 false (lambda ((x d)) (Z3 x)) U3 V3) (filter (lambda ((x d)) (Z3 x)) V3))