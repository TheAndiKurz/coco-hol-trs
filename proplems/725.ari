; @cops 725
(format HRS)
(sort nat)
(sort natlist)
(fun 0 nat)
(fun s (-> nat nat))
(fun nil natlist)
(fun cons (-> nat natlist natlist))
(fun map (-> (-> nat nat) natlist natlist))
(fun op (-> (-> nat nat) (-> nat nat) nat nat))
(fun pow (-> (-> nat nat) nat nat nat))
(fun at (-> (-> nat nat) nat nat))
(fun L (-> (-> nat nat) nat nat))
(rule (map (lambda ((x nat)) (F x)) nil) nil)
(rule (map (lambda ((x nat)) (F x)) (cons h t)) (cons (at (lambda ((x nat)) (F x)) h) (map (lambda ((x nat)) (F x)) t)))
(rule (pow (lambda ((x nat)) (F x)) 0 y) (L (lambda ((x nat)) x) y))
(rule (pow (lambda ((x nat)) (F x)) (s z) y) (op (lambda ((x nat)) (F x)) (lambda ((z nat)) (pow (lambda ((x nat)) (F x)) (s z) z)) y))
(rule (op (lambda ((x nat)) (F x)) (lambda ((x nat)) (G x)) y) (at (lambda ((x nat)) (F x)) (at (lambda ((x nat)) (G x)) y)))
(rule (L (lambda ((z nat)) (at (lambda ((x nat)) (F x)) z)) y) (F y))
(rule (L (lambda ((z nat)) (op (lambda ((x nat)) (F x)) (lambda ((x nat)) (G x)) z)) y) (op (lambda ((x nat)) (F x)) (lambda ((x nat)) (G x)) y))
(rule (at (lambda ((x nat)) (F x)) z) (F z))