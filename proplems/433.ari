; @cops 433
(format HRS)
(sort R)
(fun min (-> R R))
(fun add (-> R R R))
(fun mul (-> R R R))
(fun D (-> (-> R R) R R))
(fun sin (-> R R))
(fun cos (-> R R))
(fun 0 R)
(fun 1 R)
(rule (D (lambda ((x R)) C) z) 0)
(rule (D (lambda ((x R)) x) z) 1)
(rule (D (lambda ((x R)) (min (F x))) z) (min (D (lambda ((x R)) (F x)) z)))
(rule (D (lambda ((x R)) (add (F x) (G x))) z) (add (D (lambda ((x R)) (F x)) z) (D (lambda ((x R)) (G x)) z)))
(rule (D (lambda ((x R)) (mul (F x) (G x))) z) (add (mul (D (lambda ((x R)) (F x)) z) (G z)) (mul (F z) (D (lambda ((x R)) (G x)) z))))
(rule (D (lambda ((x R)) (sin (F x))) z) (mul (cos z) (D (lambda ((x R)) (F x)) z)))
(rule (D (lambda ((x R)) (cos (F x))) z) (mul (min (sin z)) (D (lambda ((x R)) (F x)) z)))