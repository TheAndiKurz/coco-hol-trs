; differentiation
; source: extension of Example 3.4 in Jouannaud & Rubio ACM Trans. Com. Log. 2015
(format HRS)
(sort real)
(fun zero real)
(fun one real)
(fun sin (-> real real))
(fun cos (-> real real))
(fun ln (-> real real))
(fun diff (-> (-> real real) real real))
(fun plus (-> (-> real real) (-> real real) real real))
(fun minus (-> (-> real real) real real))
(fun times (-> (-> real real) (-> real real) real real))
(fun div (-> (-> real real) (-> real real) real real))
(rule (diff (lambda ((z real)) y) X) zero)
(rule (diff (lambda ((z real)) z) X) one)
(rule (diff (lambda ((z real)) (sin (F z))) X) (times (lambda ((z real)) (cos (F z))) (lambda ((y real)) (diff (lambda ((z real)) (F z)) y)) X))
(rule (diff (lambda ((z real)) (cos (F z))) X) (times (lambda ((y real)) (minus (lambda ((z real)) (sin (F z))) y)) (lambda ((y real)) (diff (lambda ((z real)) (F z)) y)) X))
(rule (diff (lambda ((y real)) (plus (lambda ((z real)) (F z)) (lambda ((z real)) (G z)) y)) X) (plus (lambda ((y real)) (diff (lambda ((z real)) (F z)) y)) (lambda ((y real)) (diff (lambda ((z real)) (G z)) y)) X))
(rule (diff (lambda ((y real)) (times (lambda ((z real)) (F z)) (lambda ((z real)) (G z)) y)) X) (plus (lambda ((x real)) (times (lambda ((y real)) (diff (lambda ((z real)) (F z)) y)) (lambda ((z real)) (G z)) x)) (lambda ((x real)) (times (lambda ((z real)) (F z)) (lambda ((y real)) (diff (lambda ((z real)) (G z)) y)) x)) X))
(rule (diff (lambda ((z real)) (ln (F z))) X) (div (lambda ((y real)) (diff (lambda ((z real)) (F z)) y)) (lambda ((z real)) (F z)) X))
(rule (times (lambda ((z real)) (F z)) (lambda ((z real)) one) X) (F X))
(rule (times (lambda ((z real)) (F z)) (lambda ((z real)) zero) X) zero)
(rule (plus (lambda ((z real)) (F z)) (lambda ((z real)) zero) X) (F X))
(rule (div (lambda ((z real)) zero) (lambda ((z real)) (G z)) X) zero)