; @cops 517
(format HRS)
(sort a)
(fun nil a)
(fun cons (-> a a a))
(fun foldr (-> (-> a a a) a a a))
(fun build (-> (-> (-> a a a) a a) a))
(fun add (-> a a a))
(fun 0 a)
(fun s (-> a a))
(fun sum (-> a a))
(fun down (-> a a))
(fun down' (-> a (-> a a a) a a))
(rule (foldr (lambda ((x a) (y a)) (k x y)) z nil) z)
(rule (foldr (lambda ((x a) (y a)) (k x y)) z (cons x xs)) (k x (foldr (lambda ((x' a) (y a)) (k x' y)) z xs)))
(rule (build (lambda ((k (-> a a a)) (z a)) (g (lambda ((x a) (y a)) (k x y)) z))) (g (lambda ((x a) (y a)) (cons x y)) nil))
(rule (foldr (lambda ((x a) (y a)) (k x y)) z (build (lambda ((k' (-> a a a)) (z' a)) (g (lambda ((x a) (y a)) (k' x y)) z')))) (g (lambda ((x a) (y a)) (k x y)) z))
(rule (sum xs) (foldr (lambda ((x a) (y a)) (add x y)) 0 xs))
(rule (down x) (build (lambda ((k (-> a a a)) (z a)) (down' x (lambda ((x' a) (y a)) (k x' y)) z))))
(rule (down' 0 (lambda ((x a) (y a)) (k x y)) z) z)
(rule (down' (s x) (lambda ((x' a) (y a)) (k x' y)) z) (k x (down' x (lambda ((x' a) (y a)) (k x' y)) z)))
