; @author Julian Nagele
; @doi 10.1016/0304-3975(93)90091-7
; @cops 470
; [96] p. 285
(format HRS)
(sort o)
(fun P (-> o (-> o o) (-> o o) o))
(fun L (-> o o))
(fun R (-> o o))
(rule (P (L Z) (lambda ((x o)) (Z' x)) (lambda ((x o)) (Z'' x))) (Z' Z))
(rule (P (R Z) (lambda ((x o)) (Z' x)) (lambda ((x o)) (Z'' x))) (Z'' Z))