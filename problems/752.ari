; @cops 752
(format HRS)
(sort A)
(sort B)
(sort C)
(sort arrAB)
(sort SAB)
(sort PAB)
(sort vA)
(fun app (-> arrAB A B))
(fun lam (-> (-> vA B) arrAB))
(fun case (-> SAB (-> A C) (-> B C) C))
(fun inl (-> A SAB))
(fun inr (-> B SAB))
(fun piA (-> PAB A))
(fun piB (-> PAB B))
(fun pair (-> A B PAB))
(fun var (-> vA A))
(rule (app (lam (lambda ((x vA)) (M (var x)))) N) (M N))
(rule (lam (lambda ((x vA)) (app L (var x)))) L)
(rule (piA (pair M1 N1)) M1)
(rule (piB (pair M1 N1)) N1)
(rule (case (inl X) (lambda ((x A)) (F x)) (lambda ((y B)) (G y))) (F X))
(rule (case (inr Y) (lambda ((x A)) (F x)) (lambda ((x B)) (G x))) (G Y))