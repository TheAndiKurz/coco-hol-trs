; @cops 749
(format HRS)
(sort a)
(sort b)
(sort ab)
(sort BGa)
(sort BGb)
(sort BGc)
(sort BGaBGb)
(sort BGbBGc)
(fun abs (-> (-> a b) ab))
(fun app (-> ab a b))
(fun absBG (-> (-> BGa BGb) BGaBGb))
(fun appBGaBGb (-> BGaBGb BGa BGb))
(fun appBGbBGc (-> BGbBGc BGb BGc))
(fun banga (-> a BGa))
(fun let (-> BGa (-> a BGb) BGb))
(fun letbc (-> BGb (-> b BGc) BGc))
(fun letBGaBGb (-> BGa (-> a BGaBGb) BGaBGb))
(fun letac (-> BGa (-> a BGc) BGc))
(rule (app (abs (lambda ((x a)) (M x))) N) (M N))
(rule (abs (lambda ((x a)) (app S x))) S)
(rule (appBGaBGb (absBG (lambda ((x BGa)) (M1 x))) N1) (M1 N1))
(rule (absBG (lambda ((x BGa)) (appBGaBGb S1 x))) S1)
(rule (let (banga N) (lambda ((x a)) (Q x))) (Q N))
(rule (let L (lambda ((x a)) (C (banga x)))) (C L))
(rule (letbc (let L (lambda ((x a)) (Q x))) (lambda ((y b)) (K y))) (letac L (lambda ((x a)) (letbc (Q x) (lambda ((y b)) (K y))))))
(rule (appBGbBGc S2 (let L (lambda ((x a)) (Q x)))) (letac L (lambda ((x a)) (appBGbBGc S2 (Q x)))))

