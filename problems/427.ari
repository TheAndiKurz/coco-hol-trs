; @cops 427
(format HRS)
(sort T)
(sort F)
(fun not (-> F F))
(fun and (-> F F F))
(fun or (-> F F F))
(fun all (-> (-> T F) F))
(fun ex (-> (-> T F) F))
(rule (and P (all (lambda ((x T)) (Q x)))) (all (lambda ((x T)) (and P (Q x)))))
(rule (and (all (lambda ((x T)) (Q x))) P) (all (lambda ((x T)) (and (Q x) P))))
(rule (or P (all (lambda ((x T)) (Q x)))) (all (lambda ((x T)) (or P (Q x)))))
(rule (or (all (lambda ((x T)) (Q x))) P) (all (lambda ((x T)) (or (Q x) P))))
(rule (and P (ex (lambda ((x T)) (Q x)))) (ex (lambda ((x T)) (and P (Q x)))))
(rule (and (ex (lambda ((x T)) (Q x))) P) (ex (lambda ((x T)) (and (Q x) P))))
(rule (or P (ex (lambda ((x T)) (Q x)))) (ex (lambda ((x T)) (or P (Q x)))))
(rule (or (ex (lambda ((x T)) (Q x))) P) (ex (lambda ((x T)) (or (Q x) P))))
(rule (not (all (lambda ((x T)) (Q x)))) (ex (lambda ((x T)) (not (Q x)))))
(rule (not (ex (lambda ((x T)) (Q x)))) (all (lambda ((x T)) (not (Q x)))))

