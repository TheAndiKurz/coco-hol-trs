; @cops 776
(format HRS)
(sort G)
(sort Ar<G_G>)
(sort Pr<G_G>)
(sort B)
(sort L)
(fun 0 G)
(fun union (-> G G G))
(fun fix (-> (-> G G) G))
(fun fix2 (-> (-> G G Pr<G_G>) Pr<G_G>))
(fun app (-> Ar<G_G> G G))
(fun lam (-> (-> G G) Ar<G_G>))
(fun pair (-> G G Pr<G_G>))
(fun true B)
(fun false B)
(fun if (-> B G G G))
(fun cons (-> L G G))
(fun l L)
(rule (app (lam (lambda ((x G)) (M x))) N) (M N))
(rule (lam (lambda ((x G)) (app L x))) L)
(rule (union x 0) x)
(rule (union 0 y) y)
(rule (union (union x y) z) (union x (union y z)))
(rule (union x y) (union y x))
(rule (fix2 (lambda ((x1 G) (x2 G)) (pair (t1 x1 x2) (t2 x1 x2)))) (pair (fix (lambda ((y G)) (t1 y y))) (fix (lambda ((y G)) (t2 y y)))))
(rule (if true x y) x)
(rule (if false x y) y)